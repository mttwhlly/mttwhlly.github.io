---                               
import '../styles/global.css';
import Footer from '../components/Footer';
import Header from '../components/Header';
--- 
<!DOCTYPE html>
<html lang="en">
  <head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Matt Whalley – Senior/Staff AI Product Engineer · Remote</title>

  <!-- SEO -->
  <meta name="description" content="AI Product Engineer bridging AI, product, design, and engineering to turn emerging technology into products people can actually use." />
  <meta name="keywords" content="Matt Whalley, AI Product Engineer, AI Product Development, Design Systems, Agentic Workflows, Frontend Architecture, UX Engineering" />
  <meta name="author" content="Matt Whalley" />

  <!-- Open Graph Tags -->
  <meta property="og:title" content="Matt Whalley – Senior/Staff AI Product Engineer · Remote" />
  <meta property="og:description" content="Bridging AI, product, design, and engineering to turn emerging technology into products people can actually use." />
  <meta property="og:url" content="https://mattwhalley.com" />
  <!-- Optional: Uncomment when image is ready -->
  <!-- <meta property="og:image" content="https://mattwhalley.com/og-image.jpg" /> -->
  <meta property="og:type" content="website" />

  <!-- Favicon and Icons -->
  <link rel="icon" href="favicon.ico" type="image/x-icon" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#D4FC52" />
  <meta name="msapplication-TileColor" content="#D4FC52" />
  <meta name="theme-color" content="#D4FC52" />
</head>

<body class="flex flex-col min-h-screen antialiased text-gray-900 bg-white">
  <Header client:load />
  <div class="pt-20"> <!-- Add padding-top to account for fixed header -->
    <slot />
  </div>
  <Footer client:load />
</body>
</html>