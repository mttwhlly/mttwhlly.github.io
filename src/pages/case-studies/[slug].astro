---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { ArrowLeft } from '@phosphor-icons/react/dist/ssr';

export async function getStaticPaths() {
  const entries = await getCollection('caseStudies');
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.(mdx?)$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, subtitle, client, publishedDate, tags, atAGlance, coverImage } = entry.data;
---

<Layout>
  <main class="max-w-3xl mx-auto px-6 py-12">

    <!-- Back nav -->
    <a
      href="/case-studies"
      class="inline-flex items-center gap-2 text-sm font-mono uppercase tracking-widest text-gray-400 hover:text-gray-700 transition-colors mb-12"
    >
      <ArrowLeft size={14} weight="bold" client:load />
      Case Studies
    </a>

    <!-- Header -->
    <header class="mb-12">
      {coverImage && (
        <div class="mb-8 rounded-2xl overflow-hidden bg-gray-100">
          <img src={coverImage} alt="" class="w-full object-cover" />
        </div>
      )}
      <div class="flex flex-wrap gap-2 mb-6">
        {tags.map((tag) => (
          <span class="text-xs font-mono uppercase tracking-wider text-gray-500 bg-gray-100 px-3 py-1 rounded-full">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="text-3xl md:text-4xl font-sans font-bold leading-tight text-gray-900 mb-4">
        {title}
      </h1>
      <p class="text-xl font-serif italic text-gray-600 leading-relaxed mb-6">
        {subtitle}
      </p>
      <div class="flex items-center gap-4 text-sm font-mono text-gray-400 border-t border-gray-100 pt-6">
        <span>{client}</span>
        <span>·</span>
        <span>{publishedDate}</span>
      </div>
    </header>

    <!-- At a glance -->
    {atAGlance && (
      <div class="mb-12 border border-gray-200 rounded-2xl overflow-hidden">
        <div class="bg-gray-50 border-b border-gray-200 px-6 py-3">
          <span class="text-xs font-mono uppercase tracking-widest text-gray-500">At a glance</span>
        </div>
        <div class="divide-y divide-gray-100">
          {atAGlance.map(({ label, value }) => (
            <div class="flex gap-6 px-6 py-4">
              <span class="text-sm font-mono text-gray-400 w-36 shrink-0">{label}</span>
              <span class="text-sm text-gray-700">{value}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Body -->
    <article class="prose-case-study">
      <Content />
    </article>

    <!-- Footer nav -->
    <div class="mt-16 pt-8 border-t border-gray-200">
      <a
        href="/case-studies"
        class="inline-flex items-center gap-2 text-sm font-mono uppercase tracking-widest text-gray-400 hover:text-gray-700 transition-colors"
      >
        <ArrowLeft size={14} weight="bold" client:load />
        All Case Studies
      </a>
    </div>

  </main>
</Layout>
